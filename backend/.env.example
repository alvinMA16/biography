# 数据库配置（本地开发用SQLite，生产环境换成PostgreSQL）
DATABASE_URL=sqlite:///./biography.db

# 通义千问 API配置（去 https://dashscope.console.aliyun.com/ 获取）
DASHSCOPE_API_KEY=your_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus

# 阿里云语音识别配置（去 https://nls-portal.console.aliyun.com/ 获取）
ALIYUN_AK_ID=your_ak_id_here
ALIYUN_AK_SECRET=your_ak_secret_here
ALIYUN_NLS_APPKEY=your_appkey_here

# 认证配置
JWT_SECRET=change-me-in-production
JWT_EXPIRE_DAYS=30
ADMIN_API_KEY=your_admin_key_here

# 调试模式
DEBUG=true

# LLM Provider 路由
# 全局默认 provider（dashscope / gemini）
LLM_PROVIDER_DEFAULT=dashscope
# 模块级 override（留空 = 用全局默认）
# LLM_PROVIDER_MEMOIR=
# LLM_PROVIDER_SUMMARY=
# LLM_PROVIDER_TOPIC=
# LLM_PROVIDER_PROFILE=
# LLM_PROVIDER_INTERVENTION=

# Google Gemini（原生 SDK 直连）
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_SOCK5_PROXY=socks5://127.0.0.1:1080       # 同步调用代理（支持 socks5）
# GEMINI_HTTP_PROXY=http://127.0.0.1:8118           # 异步调用代理（不支持 socks5）
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MODEL_FAST=gemini-2.0-flash-lite
